<?xml version="1.0" encoding="utf-8"?>
<!-- 提词文稿卡片布局 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/script_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_script_card"
    android:layout_marginBottom="12dp">

    <!-- 卡片内容区域（可点击） -->
    <LinearLayout
        android:id="@+id/card_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">

        <!-- 标题和时长 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/card_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="文稿标题"
                android:textColor="#F5F5F7"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 时长标签 -->
            <TextView
                android:id="@+id/card_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~1分钟"
                android:textColor="#636366"
                android:textSize="11sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 内容预览 -->
        <TextView
            android:id="@+id/card_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="预览内容..."
            android:textColor="#A1A1A6"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 元数据：字数、创建时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/card_char_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="156字"
                android:textColor="#636366"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="#636366"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/card_created_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今天"
                android:textColor="#636366"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 操作按钮区域（默认隐藏） -->
    <LinearLayout
        android:id="@+id/card_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 顶部分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#14FFFFFF" />

        <!-- 按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 编辑按钮 -->
            <LinearLayout
                android:id="@+id/action_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_edit"
                    android:tint="#E8A838" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="编辑"
                    android:textColor="#E8A838"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                android:background="#14FFFFFF" />

            <!-- 删除按钮 -->
            <LinearLayout
                android:id="@+id/action_delete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_delete"
                    android:tint="#FF453A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="删除"
                    android:textColor="#FF453A"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                android:background="#14FFFFFF" />

            <!-- 录制按钮 -->
            <LinearLayout
                android:id="@+id/action_record"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_record"
                    android:tint="#32D7A0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="录制"
                    android:textColor="#32D7A0"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>